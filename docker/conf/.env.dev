APP_NAME=workshop
NODE_VERSION=24.11.0-alpine3.22
NODE_ENV=development
TZ=Europe/Paris
UID=1000
GID=1000
HOME_PATH=/home/user/
WORKSHOP_HOST=${APP_NAME}

ENV_NAME=local
DEFAULT_PORT=3000
SERVER_SCHEME=http://
SERVER_URL=localhost
STACK_NAME=${APP_NAME}-${ENV_NAME}

# Liquibase 
LIQUIBASE_VERSION=4.28.0-alpine
LIQUIBASE_DB_USER=liquibase
LIQUIBASE_DB_PWD=mdppourliquibase
LIQUIBASE_LOG_LEVEL=INFO
LIQUIBASE_UPDATE=1
LIQUIBASE_SNAPSHOT=1
LIQUIBASE_COMMAND_CONTEXTS=v1,oauth
LIQUIBASE_ROLLBACK=0

# Postgres
POSTGRES_HOST=${APP_NAME}-postgres-${ENV_NAME}
POSTGRES_VERSION=postgres:16.2-alpine3.19
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5432
POSTGRES_ROOT_USER=root
POSTGRES_ROOT_PWD=mdppourroot
POSTGRES_DBS=liquibase,workshop

#TRAEFIK
TRAEFIK_HOST=${APP_NAME}-traefik-${ENV_NAME}
TRAEFIK_VERSION=3.6.4
TRAEFIK_ACCESSLOG=true
TRAEFIK_API_INSECURE=true
TRAEFIK_ENTRYPOINTS_WEB_ADDRESS=":80"
TRAEFIK_ENTRYPOINTS_WEB_FORWARDEDHEADERS_INSECURE=false
TRAEFIK_PROVIDERS_DOCKER_EXPOSEDBYDEFAULT=false
TRAEFIK_LOG_LEVEL="DEBUG"
TRAEFIK_PING=true
TRAEFIK_DASH_PORT=8084
TRAEFIK_PORT=8101
TRAEFIK_PREFIX=/api
TRAEFIK_PUBLIC_URL=${SERVER_SCHEME}${SERVER_URL}:${TRAEFIK_PORT}${TRAEFIK_PREFIX}/

# Workshop
WORKSHOP_DB_NAME=workshop
WORKSHOP_DB_USER=workshop_3668af4c
WORKSHOP_DB_PWD=mdppourworkshopdb
WORKSHOP_PWD_CHECK_URL=${MSAUTH_VERIFY_URL}
WORKSHOP_USER_SEARCH_URL=${MSUSER_SEARCH_URL}
WORKSHOP_ACCESS_TOKEN_DURATION=600 #10 * 60 => 10 mins
WORKSHOP_REFRESH_TOKEN_DURATION=86400 #24 * 60 * 60 => 1 day
WORKSHOP_MIGRATION_SERVICE_NAME=${APP_NAME}-migration
WORKSHOP_MIGRATION_HOST=${APP_NAME}-${WORKSHOP_MIGRATION_SERVICE_NAME}-${ENV_NAME}
